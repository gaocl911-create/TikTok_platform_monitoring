APP_NAME=Creator Monitoring API
APP_ENV=development
API_V1_PREFIX=/api/v1

MYSQL_DATABASE=creator_monitoring
MYSQL_USER=monitoring
MYSQL_PASSWORD=monitoring_password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=13306
MYSQL_EXPOSE_PORT=13306

REDIS_HOST=127.0.0.1
REDIS_PORT=16379
REDIS_EXPOSE_PORT=16379
REDIS_DB=0

VITE_API_BASE_URL=http://localhost:8001/api/v1
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# 可填写飞书、企业微信或兼容 JSON Webhook 地址
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_SECONDS=5

# 抖音真实公开主页采集使用本机 Edge，无需登录态。
DOUYIN_BROWSER_PATH=
DOUYIN_RENDER_TIMEOUT_SECONDS=75
DOUYIN_VIRTUAL_TIME_BUDGET_MS=15000

# 采集任务去重、有限重试与连续失败预警
COLLECTION_LOCK_TTL_SECONDS=180
COLLECTION_RETRY_MAX_RETRIES=3
COLLECTION_RETRY_BASE_DELAY_SECONDS=30
COLLECTION_FAILURE_ALERT_THRESHOLD=3

# TikHub Douyin API. Mainland China usually uses https://api.tikhub.dev.
TIKHUB_ENABLED=true
TIKHUB_API_BASE_URL=https://api.tikhub.dev
TIKHUB_API_TOKEN=
TIKHUB_TIMEOUT_SECONDS=15
TIKHUB_DAILY_BUDGET_USD=5
TIKHUB_ESTIMATED_UNIT_PRICE_USD=0.001

# Provider switches. TikHub is the only active real Douyin API provider.
DOUYIN_SINGLE_WORK_PROVIDER=tikhub
DOUYIN_PROFILE_PROVIDER=tikhub
